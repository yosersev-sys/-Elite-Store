# إعدادات التخزين المؤقت للصور (Browser Caching)
# سوق العصر

<IfModule mod_expires.c>
    ExpiresEngine On
    ExpiresActive On
    
    # تخزين الصور مؤقتاً في المتصفح لمدة سنة كاملة
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # تعيين قيمة التحكم في التخزين المؤقت للمتصفحات والشبكات الوسيطة (CDN)
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|ico)$">
        Header set Cache-Control "max-age=31536000, public, no-transform"
    </FilesMatch>
</IfModule>

# منع استعراض محتويات المجلد لأسباب أمنية
Options -Indexes
